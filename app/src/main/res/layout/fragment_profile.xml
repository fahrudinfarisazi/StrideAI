<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color">

    <RelativeLayout
        android:id="@+id/topBarProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="STRIDE AI"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <ImageView
            android:id="@+id/btnHistoryProfile"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_recent_history"
            app:tint="@color/text_primary" />


    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/topBarProfile"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Avatar Box -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAvatar"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardBackgroundColor="@color/card_bg_color"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/color_primary">
                    <ImageView
                        android:id="@+id/imgAvatarProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="#B0BEC5"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Verified Badge -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignEnd="@id/cardAvatar"
                    android:layout_alignBottom="@id/cardAvatar"
                    android:layout_marginEnd="-6dp"
                    android:layout_marginBottom="-6dp"
                    android:src="@drawable/ic_verified"
                    android:elevation="4dp"/>

                <TextView
                    android:id="@+id/tvRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/cardAvatar"
                    android:layout_marginTop="16dp"
                    android:text="STRIDE ATHLETE"
                    android:textColor="@color/color_primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/tvRole"
                    android:layout_marginTop="4dp"
                    android:text="-"
                    tools:text="Faris Azi"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvPhysicalStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/tvName"
                    android:layout_marginTop="8dp"
                    android:text="-"
                    tools:text="Female • 172 cm • 62 kg"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.1"/>

                <LinearLayout
                    android:id="@+id/layStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/tvPhysicalStats"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvStreakCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            tools:text="42"
                            android:textColor="@android:color/white"
                            android:textSize="32sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STREAK"
                            android:textColor="#B0BEC5"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="32dp"
                        android:layout_marginHorizontal="24dp"
                        android:background="@color/text_secondary"
                        android:alpha="0.2" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvMonthlyRunsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            tools:text="542"
                            android:textColor="@android:color/white"
                            android:textSize="32sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MONTHLY RUNS"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditProfile"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_below="@+id/layStats"
                    android:layout_marginTop="24dp"
                    android:text="EDIT PROFILE"
                    android:textColor="@color/text_inverse"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/color_primary_dark"
                    app:cornerRadius="8dp" />


            </RelativeLayout>

            <!-- Medal Cabinet Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/card_bg_color"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                            <ImageView
                                android:id="@+id/icMedal"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_medal"
                                app:tint="@color/color_primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@+id/icMedal"
                            android:layout_marginStart="8dp"
                            android:layout_centerVertical="true"
                            android:text="MEDAL CABINET"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:text="VIEW ALL"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"/>
                    </RelativeLayout>

                    <!-- 2x2 Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal"
                        android:weightSum="2">
                        
                        <!-- Medal 1 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                app:cardBackgroundColor="@color/input_bg_color"
                                app:cardCornerRadius="12dp"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_medal"
                                    app:tint="#FFC107" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="-"
                                tools:text="GOLD STREAK"
                                android:textColor="@color/text_primary"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                tools:text="30 DAY BURST"
                                android:textColor="@color/text_secondary"
                                android:textSize="8sp"/>
                        </LinearLayout>

                        <!-- Medal 2 -->
                         <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                app:cardBackgroundColor="@color/input_bg_color"
                                app:cardCornerRadius="12dp"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@android:drawable/ic_menu_manage"
                                    app:tint="#B0BEC5" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="-"
                                tools:text="IRON LUNGS"
                                android:textColor="@color/text_primary"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                tools:text="10K CLIMB"
                                android:textColor="@color/text_secondary"
                                android:textSize="8sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal"
                        android:weightSum="2">
                        
                        <!-- Medal 3 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                app:cardBackgroundColor="@color/input_bg_color"
                                app:cardCornerRadius="12dp"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_medal"
                                    app:tint="#FF5722" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="-"
                                tools:text="EARLY BIRD"
                                android:textColor="@color/text_primary"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                tools:text="5AM START"
                                android:textColor="@color/text_secondary"
                                android:textSize="8sp"/>
                        </LinearLayout>

                        <!-- Medal 4 - Locked -->
                         <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                app:cardBackgroundColor="#1F2533"
                                app:cardCornerRadius="12dp"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@android:drawable/ic_secure"
                                    app:tint="#37474F" /> 
                            </com.google.android.material.card.MaterialCardView>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="-"
                                tools:text="CENTURION"
                                android:textColor="#546E7A"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                tools:text="LOCKED"
                                android:textColor="#37474F"
                                android:textSize="8sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Latest Activity -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#1A1F2B"
                app:cardCornerRadius="8dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/neon_blue" />
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">
                        
                        <TextView
                            android:id="@+id/tvLatestActivityTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LATEST ACTIVITY"
                            android:textColor="@color/neon_blue"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <TextView
                            android:id="@+id/tvLatestActivityName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/tvLatestActivityTitle"
                            android:layout_marginTop="12dp"
                            android:text="-"
                            tools:text="MORNING SPRINT"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/tvLatestActivityName"
                            android:layout_marginTop="4dp"
                            android:text="-"
                            tools:text="4.2 KM • 18:04 MIN"
                            android:textColor="#B0BEC5"
                            android:textSize="12sp"/>

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chart_bar" />
                            
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Personal Bests -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#1A1F2B"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_rocket"
                            app:tint="@color/neon_blue" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="PERSONAL BESTS"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                    </LinearLayout>

                    <!-- Row 1 -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MAX SPEED" android:textColor="#B0BEC5" android:textSize="12sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="-" tools:text="18.4 km/h" android:textColor="@android:color/white" android:textSize="14sp" android:textStyle="bold"/>
                    </RelativeLayout>
                    <!-- Row 2 -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL KM" android:textColor="#B0BEC5" android:textSize="12sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="-" tools:text="1,248.0" android:textColor="@android:color/white" android:textSize="14sp" android:textStyle="bold"/>
                    </RelativeLayout>
                    <!-- Row 3 -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ACTIVE DAYS" android:textColor="#B0BEC5" android:textSize="12sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="-" tools:text="142" android:textColor="@android:color/white" android:textSize="14sp" android:textStyle="bold"/>
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Kinetic Momentum -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#1A1F2B"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingTop="20dp"
                    android:paddingHorizontal="20dp">
                    
                    <TextView
                        android:id="@+id/tvKineticTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KINETIC MOMENTUM (7D)"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <!-- Simulate Graph -->
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_alignParentBottom="true"
                        android:scaleType="fitXY"
                        tools:src="@drawable/ic_intensity_graph"
                        android:alpha="0.8" />
                        
                    <!-- Badge -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        app:cardBackgroundColor="#11333B"
                        app:cardCornerRadius="8dp"
                        app:strokeColor="#22636B"
                        app:strokeWidth="1dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="8dp"
                            android:text="-\n-"
                            tools:text="+14% EFFICIENCY\nINCREASE"
                            android:textColor="@color/neon_blue"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:letterSpacing="0.1"/>
                    </com.google.android.material.card.MaterialCardView>

                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="160dp"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="40dp"
                android:layout_gravity="center_horizontal"
                android:text="LOGOUT"
                android:textColor="#FF8A80"
                android:textSize="12sp"
                android:textStyle="bold"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#3E2723"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_logout"
                app:iconTint="#FF8A80"
                app:iconGravity="textStart"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>